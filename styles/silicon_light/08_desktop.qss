QMenuBar[kireiRole="menuBar"] {
    background: #F8FAFF;
    border-bottom: 1px solid #E2E8F6;
}
QMenuBar[kireiRole="menuBar"]::item {
    padding: 6px 10px;
    border-radius: 8px;
}
QMenuBar[kireiRole="menuBar"]::item:selected {
    background: #EEF2FF;
}

QStatusBar[kireiRole="statusBar"] {
    background: #F4F7FE;
    border-top: 1px solid #E2E8F6;
}

QFileDialog,
QColorDialog {
    background: #F7F9FE;
}
